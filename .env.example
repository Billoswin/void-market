# Void Market environment (.env)
# The app reads this file with prefix VM_ (see app/config.py).

# Server
VM_HOST=127.0.0.1
VM_PORT=8585
VM_DEBUG=false

# EVE SSO / ESI (create an application in the CCP Developer Portal)
VM_ESI_CLIENT_ID=YOUR_CLIENT_ID_HERE
VM_ESI_CLIENT_SECRET=

# LAN-only option (register this exact URL as the callback in CCP portal):
# VM_ESI_CALLBACK_URL=http://<unraid-ip>:8585/auth/callback
VM_ESI_CALLBACK_URL=http://127.0.0.1:8585/auth/callback

# Alliance + structure IDs (set after you know them)
VM_ALLIANCE_ID=0
VM_KEEPSTAR_STRUCTURE_ID=0

# Optional: adjust economics defaults
VM_FREIGHT_COST_PER_M3=1350.0
VM_DEFAULT_MARKUP_PCT=20.0
